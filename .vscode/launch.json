{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Go App",
            "type": "go",
            "request": "launch",
            "program": "${workspaceFolder}/main.go",
            "args": [
                "${workspaceFolder}/stocks.json"
            ],
            "env": {
                "DB_USER": "your_db_user",
                "DB_PASSWORD": "your_db_password",
                "DB_HOST": "localhost",
                "DB_PORT": "50432",
                "DB_NAME": "stock_monitoring"
            },
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}