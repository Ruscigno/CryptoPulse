# Copy to .env and fill in. The .env file is git-ignored — never commit real secrets.
# These vars drive both the Go binary (dsnFromEnv) and docker-compose.

DB_USER=screener
DB_PASSWORD=change-me
DB_NAME=stock_screener
DB_HOST=localhost
DB_PORT=5432

# Postgres TLS mode. Default in code is "require". Note "require" only encrypts;
# it does NOT verify the server certificate — use "verify-full" in production
# (with a CA) to prevent MITM. For the local docker-compose Postgres (no TLS
# configured) use "disable".
DB_SSLMODE=disable
